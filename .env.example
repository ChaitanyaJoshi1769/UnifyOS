# Application
NODE_ENV=development
LOG_LEVEL=info

# API Gateway
API_GATEWAY_PORT=3000
CORS_ORIGIN=*

# Admin Portal
ADMIN_PORTAL_PORT=3000

# User Portal
USER_PORTAL_PORT=3001

# Database
DATABASE_URL=postgresql://unifyos:unifyos_dev_password@localhost:5432/unifyos
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# MongoDB
MONGODB_URL=mongodb://unifyos:unifyos_dev_password@localhost:27017/unifyos

# Neo4j
NEO4J_URL=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=unifyos_dev_password

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant_dev_key

# MinIO (Object Storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=unifyos

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=unifyos-client

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (Email)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@unifyos.local

# LLM Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus

GEMINI_API_KEY=

# Feature Flags
FEATURE_KNOWLEDGE_GRAPH=true
FEATURE_COPILOT=true
FEATURE_COMPLIANCE_REPORTING=true

# Monitoring
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=true
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# S3-compatible storage
S3_REGION=us-east-1
S3_ENDPOINT=
S3_BUCKET=unifyos

# Connector Configuration
CONNECTOR_TIMEOUT=300000
CONNECTOR_MAX_RETRIES=3
CONNECTOR_RETRY_BACKOFF=1000
